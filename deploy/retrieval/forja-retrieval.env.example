# Copy only into the Forja retrieval deployment's secret/configuration boundary.
# This file contains no credential values and must not be used as a shared
# application environment. The AWS SDK resolves credentials from workload
# identity or another approved standard provider chain.

FORJA_DATABASE_URL=
FORJA_TENANT_ID=
FORJA_REPOSITORY_ID=
FORJA_QDRANT_HOST=
FORJA_QDRANT_GRPC_PORT=6334
FORJA_QDRANT_TLS=true
FORJA_RETRIEVAL_COLLECTION=
FORJA_S3_BUCKET=
FORJA_S3_REGION=
FORJA_S3_ENDPOINT=
FORJA_S3_PATH_STYLE=false
AWS_REGION=

# Never set these legacy application credential variables for Forja. The
# runtime rejects them before it opens any dependency.
# CHAVE_API_AWS_BEDROCK=
# AWS_BEARER_TOKEN_BEDROCK=
