{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-evaluation-outcomes.schema.json",
  "title": "Forja Retrieval Evaluation Outcomes",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "outcomes"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "corpus_id": {"type": "string", "pattern": "^retrieval_eval_[a-z0-9_-]{1,160}$"},
    "outcomes": {
      "type": "array", "minItems": 1, "maxItems": 100000,
      "items": {
        "type": "object", "additionalProperties": false,
          "required": ["case_id", "accepted_entity_ids", "latency_milliseconds", "projection_lag_events"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1, "maxLength": 200},
            "accepted_entity_ids": {
              "type": "array", "maxItems": 1000, "uniqueItems": true,
              "items": {"type": "string", "minLength": 1, "maxLength": 256}
            },
            "latency_milliseconds": {"type": "integer", "minimum": 0, "maximum": 30000},
            "projection_lag_events": {"type": "integer", "minimum": 0, "maximum": 1000000}
          }
      }
    }
  }
}
