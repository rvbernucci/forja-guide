{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-query.schema.json",
  "title": "Forja Governed Retrieval Query",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id", "schema_version", "tenant_id", "repository_id", "query",
    "scope", "filters", "policy"
  ],
  "properties": {
    "request_id": {"type": "string", "pattern": "^retrieval_request_[A-Za-z0-9_-]{1,200}$"},
    "schema_version": {"const": "1.0"},
    "tenant_id": {"type": "string", "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "query": {"type": "string", "minLength": 1, "maxLength": 16384},
    "scope": {
      "type": "object", "additionalProperties": false,
      "required": ["source_commit", "allowed_paths"],
      "properties": {
        "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
        "allowed_paths": {
          "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "denied_paths": {
          "type": "array", "maxItems": 256, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        }
      }
    },
    "filters": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_families", "authority_classes"],
      "properties": {
        "artifact_families": {
          "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true,
          "items": {"enum": ["symbol", "decision", "test", "memory", "incident"]}
        },
        "authority_classes": {
          "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true,
          "items": {"enum": ["canonical", "supporting", "candidate"]}
        },
        "languages": {
          "type": "array", "maxItems": 32, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        },
        "symbol_kinds": {
          "type": "array", "maxItems": 64, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        }
      }
    },
    "policy": {
      "type": "object", "additionalProperties": false,
      "required": ["limit", "dense_limit", "sparse_limit", "dense_weight", "sparse_weight", "rrf_k"],
      "properties": {
        "limit": {"type": "integer", "minimum": 1, "maximum": 100},
        "dense_limit": {"type": "integer", "minimum": 1, "maximum": 200},
        "sparse_limit": {"type": "integer", "minimum": 1, "maximum": 200},
        "dense_weight": {"type": "number", "minimum": 0, "maximum": 10},
        "sparse_weight": {"type": "number", "minimum": 0, "maximum": 10},
        "rrf_k": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    },
    "expected_generation": {"type": "string", "pattern": "^retrieval_generation_[a-f0-9]{64}$"}
  }
}
