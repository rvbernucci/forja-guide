{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/file-card.schema.json",
  "title": "Forja File Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "file_id", "lineage_id", "schema_version", "snapshot_id", "repository_id",
    "source_commit", "path", "git_blob_id", "source_hash", "size_bytes",
    "language", "generated", "symbol_ids", "diagnostics"
  ],
  "properties": {
    "file_id": {"type": "string", "pattern": "^file_[a-f0-9]{64}$"},
    "lineage_id": {"type": "string", "pattern": "^file_lineage_[a-f0-9]{64}$"},
    "schema_version": {"const": "1.0"},
    "snapshot_id": {"type": "string", "pattern": "^snapshot_[a-f0-9]{64}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
    "path": {"type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^[^/\\\\](?:.*[^/\\\\])?$"},
    "git_blob_id": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
    "source_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 0, "maximum": 16777216},
    "language": {"enum": ["go", "typescript", "javascript", "python", "json", "yaml", "markdown", "other"]},
    "generated": {"type": "boolean"},
    "symbol_ids": {
      "type": "array", "maxItems": 100000, "uniqueItems": true,
      "items": {"type": "string", "pattern": "^symbol_[a-f0-9]{64}$"}
    },
    "diagnostics": {
      "type": "array", "maxItems": 4096,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["severity", "code", "count"],
        "properties": {
          "severity": {"enum": ["info", "warning", "error"]},
          "code": {"type": "string", "minLength": 1, "maxLength": 160},
          "count": {"type": "integer", "minimum": 1, "maximum": 1000000}
        }
      }
    }
  }
}
