{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-evaluation-corpus.schema.json",
  "title": "Forja Retrieval Evaluation Corpus",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "split", "cases"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "corpus_id": {"type": "string", "pattern": "^retrieval_eval_[a-z0-9_-]{1,160}$"},
    "split": {"enum": ["public", "tuning", "holdout", "ood", "adversarial", "regression"]},
    "cases": {
      "type": "array", "minItems": 1, "maxItems": 100000, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["case_id"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1, "maxLength": 200},
          "required_entity_ids": {
            "type": "array", "minItems": 1, "maxItems": 1000, "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 256}
          },
          "expected_no_accepted": {"const": true},
          "safety_class": {
            "enum": ["stale", "cross_tenant", "unauthorized", "malformed", "scope_bypass"]
          }
        },
        "oneOf": [
          {"required": ["required_entity_ids"]},
          {"required": ["expected_no_accepted"]}
        ],
        "allOf": [
          {
            "if": {"required": ["expected_no_accepted"]},
            "then": {"required": ["safety_class"]},
            "else": {"not": {"required": ["safety_class"]}}
          }
        ]
      }
    }
  }
}
