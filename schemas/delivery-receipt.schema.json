{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/delivery-receipt.schema.json",
  "title": "Forja Published Delivery Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "delivery_id", "tenant_id", "repository_id", "schema_version", "status", "base_commit",
    "result_commit", "result_tree", "patch_sha256", "changed_paths",
    "publication_ref", "publication_previous_commit", "author_id",
    "validator_id", "lease_fences", "validation_report_ref",
    "evidence_manifest_ref", "created_at", "published_at"
  ],
  "properties": {
    "delivery_id": {"type": "string", "pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "tenant_id": {"type": "string", "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "schema_version": {"const": "1.1"},
    "status": {"const": "published"},
    "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "result_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "result_tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "patch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "changed_paths": {
      "type": "array", "minItems": 1, "maxItems": 2048, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 4096}
    },
    "publication_ref": {"type": "string", "pattern": "^refs/forja/deliveries/[A-Za-z0-9][A-Za-z0-9._/-]{0,255}$"},
    "publication_previous_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "author_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "validator_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "lease_fences": {
      "type": "array", "minItems": 3, "maxItems": 1024, "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_type", "resource_id", "owner_id", "fencing_token"],
        "properties": {
          "resource_type": {"enum": ["worktree", "file", "artifact"]},
          "resource_id": {"type": "string", "minLength": 1, "maxLength": 500},
          "owner_id": {"type": "string", "minLength": 1, "maxLength": 500},
          "fencing_token": {"type": "integer", "minimum": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"resource_type": {"const": "worktree"}}},
            "then": {"properties": {"resource_id": {"pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"}}}
          }
        ]
      }
    },
    "validation_report_ref": {"type": "string", "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]*(/[A-Za-z0-9_-][A-Za-z0-9._-]*)*#sha256=[0-9a-f]{64}$", "maxLength": 4096},
    "evidence_manifest_ref": {"type": "string", "pattern": "^[A-Za-z0-9_-][A-Za-z0-9._-]*(/[A-Za-z0-9_-][A-Za-z0-9._-]*)*#sha256=[0-9a-f]{64}$", "maxLength": 4096},
    "created_at": {"type": "string", "format": "date-time"},
    "published_at": {"type": "string", "format": "date-time"}
  }
}
