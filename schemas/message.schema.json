{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/message.schema.json",
  "title": "Forja Immutable Message",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_id",
    "schema_version",
    "tenant_id",
    "repository_id",
    "conversation_id",
    "sequence_number",
    "role",
    "author_id",
    "content_hash",
    "content_parts",
    "citations",
    "created_at"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "pattern": "^message_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "schema_version": {"const": "1.0"},
    "tenant_id": {
      "type": "string",
      "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "repository_id": {
      "type": "string",
      "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "conversation_id": {
      "type": "string",
      "pattern": "^conversation_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "sequence_number": {"type": "integer", "minimum": 1},
    "role": {"enum": ["human", "assistant", "system", "tool"]},
    "author_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "supersedes_message_id": {
      "type": "string",
      "pattern": "^message_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "content_parts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "#/$defs/content_part"}
    },
    "citations": {
      "type": "array",
      "maxItems": 128,
      "items": {"$ref": "#/$defs/citation"}
    },
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "content_part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part_id",
        "ordinal",
        "kind",
        "artifact_id",
        "content_hash",
        "media_type",
        "size_bytes"
      ],
      "properties": {
        "part_id": {
          "type": "string",
          "pattern": "^part_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 63},
        "kind": {
          "enum": [
            "text",
            "json",
            "code",
            "image",
            "audio",
            "video",
            "file",
            "tool_call",
            "tool_result"
          ]
        },
        "artifact_id": {
          "type": "string",
          "pattern": "^artifact_[A-Za-z0-9_-]+$"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "media_type": {"type": "string", "minLength": 3, "maxLength": 120},
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967296
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_id",
        "ordinal",
        "source_artifact_id",
        "source_content_hash",
        "locator"
      ],
      "properties": {
        "citation_id": {
          "type": "string",
          "pattern": "^citation_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "ordinal": {"type": "integer", "minimum": 0, "maximum": 127},
        "source_artifact_id": {
          "type": "string",
          "pattern": "^artifact_[A-Za-z0-9_-]+$"
        },
        "source_content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "locator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "enum": ["whole", "line_range", "page_range", "time_range", "json_pointer", "uri_fragment"]
            },
            "value": {"type": "string", "minLength": 1, "maxLength": 500}
          }
        }
      }
    }
  }
}
