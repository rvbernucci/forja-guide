{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/worker-task.schema.json",
  "title": "Forja Worker Task",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "attempt_id", "run_id", "schema_version", "role", "objective", "repository_path", "worktree_path", "read_scopes", "write_scopes", "result_schema_ref", "evidence_output_dir", "attempt_ordinal", "budgets"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "run_id": {"type": "string", "pattern": "^run_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "schema_version": {"const": "1.0"},
    "role": {"enum": ["planner", "implementer", "reviewer", "tester"]},
    "objective": {"type": "string", "minLength": 3, "maxLength": 8000},
    "repository_path": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "worktree_path": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "read_scopes": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "write_scopes": {
      "type": "array", "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "context_pack_ref": {"type": ["string", "null"], "pattern": "^(artifact|context)_[A-Za-z0-9_-]+$"},
    "result_schema_ref": {"const": "https://forja.dev/schemas/worker-report.schema.json"},
    "evidence_output_dir": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "attempt_ordinal": {"type": "integer", "minimum": 1},
    "model": {"type": ["string", "null"], "minLength": 1, "maxLength": 200},
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_clock_ms", "inactivity_ms", "max_output_bytes", "cancellation_grace_ms", "max_retries"],
      "properties": {
        "wall_clock_ms": {"type": "integer", "minimum": 100, "maximum": 86400000},
        "inactivity_ms": {"type": "integer", "minimum": 100, "maximum": 3600000},
        "max_output_bytes": {"type": "integer", "minimum": 1024, "maximum": 16777216},
        "cancellation_grace_ms": {"type": "integer", "minimum": 10, "maximum": 30000},
        "max_retries": {"type": "integer", "minimum": 0, "maximum": 10},
        "max_tokens": {"type": ["integer", "null"], "minimum": 1},
        "max_commands": {"type": ["integer", "null"], "minimum": 1, "maximum": 10000}
      }
    }
  }
}
