{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-evaluation-query-plan.schema.json",
  "title": "Forja Private Retrieval Evaluation Query Plan",
  "description": "Private runtime input without expected entities or safety labels. The companion corpus is held separately by the evaluation operator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "queries", "policies"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "corpus_id": {"type": "string", "pattern": "^retrieval_eval_[a-z0-9_-]{1,160}$"},
    "queries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "query"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1, "maxLength": 200},
          "query": {"$ref": "https://forja.dev/schemas/retrieval-query.schema.json"}
        }
      }
    },
    "policies": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "policy"],
        "properties": {
          "name": {"enum": ["lexical_only", "dense_only", "rrf_unweighted", "rrf_weighted"]},
          "policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["limit", "dense_limit", "sparse_limit", "dense_weight", "sparse_weight", "rrf_k"],
            "properties": {
              "limit": {"type": "integer", "minimum": 1, "maximum": 1000},
              "dense_limit": {"type": "integer", "minimum": 0, "maximum": 10000},
              "sparse_limit": {"type": "integer", "minimum": 0, "maximum": 10000},
              "dense_weight": {"type": "number", "minimum": 0, "maximum": 100},
              "sparse_weight": {"type": "number", "minimum": 0, "maximum": 100},
              "rrf_k": {"type": "integer", "minimum": 1, "maximum": 10000}
            }
          }
        }
      }
    }
  }
}
