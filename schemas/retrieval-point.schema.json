{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-point.schema.json",
  "title": "Forja Retrieval Point",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "point_id", "schema_version", "collection_generation", "tenant_id",
    "repository_id", "entity_id", "artifact_family", "source_hash",
    "card_text", "card_text_hash", "status", "authority_class", "stale",
    "proof_refs", "graph_node_ids", "dense", "sparse", "embedding"
  ],
  "properties": {
    "point_id": {"type": "string", "pattern": "^retrieval_[a-f0-9]{64}$"},
    "schema_version": {"const": "1.0"},
    "collection_generation": {"type": "string", "pattern": "^retrieval_generation_[a-f0-9]{64}$"},
    "tenant_id": {"type": "string", "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "entity_id": {"type": "string", "pattern": "^(?:symbol|file|artifact|memory|decision|test|incident)_[A-Za-z0-9_-]{1,200}$"},
    "artifact_family": {"enum": ["symbol", "decision", "test", "memory", "incident"]},
    "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
    "source_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "card_text": {"type": "string", "minLength": 1, "maxLength": 32768},
    "card_text_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "status": {"enum": ["active", "superseded", "tombstoned"]},
    "authority_class": {"enum": ["canonical", "supporting", "candidate"]},
    "stale": {"type": "boolean"},
    "language": {"type": "string", "minLength": 1, "maxLength": 80},
    "symbol_kind": {"type": "string", "minLength": 1, "maxLength": 80},
    "repository_path": {"type": "string", "minLength": 1, "maxLength": 4096},
    "proof_refs": {
      "type": "array", "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 512}
    },
    "graph_node_ids": {
      "type": "array", "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 256}
    },
    "dense": {
      "type": "array", "minItems": 1, "maxItems": 4096,
      "items": {"type": "number"}
    },
    "sparse": {
      "type": "object", "additionalProperties": false,
      "required": ["indices", "values"],
      "properties": {
        "indices": {
          "type": "array", "minItems": 1, "maxItems": 8192,
          "items": {"type": "integer", "minimum": 0, "maximum": 4294967295}
        },
        "values": {
          "type": "array", "minItems": 1, "maxItems": 8192,
          "items": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "embedding": {
      "type": "object", "additionalProperties": false,
      "required": ["model", "version", "dimensions", "sparse_encoder_version", "embedded_at"],
      "properties": {
        "model": {"type": "string", "minLength": 1, "maxLength": 200},
        "version": {"type": "string", "minLength": 1, "maxLength": 160},
        "dimensions": {"type": "integer", "minimum": 1, "maximum": 4096},
        "sparse_encoder_version": {"type": "string", "minLength": 1, "maxLength": 160},
        "embedded_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
