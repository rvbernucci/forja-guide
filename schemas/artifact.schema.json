{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/artifact.schema.json",
  "title": "Forja Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "schema_version",
    "tenant_id",
    "repository_id",
    "kind",
    "status",
    "content_hash",
    "media_type",
    "created_at",
    "created_by",
    "provenance"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^artifact_[A-Za-z0-9_-]+$"
    },
    "schema_version": {
      "const": "1.0"
    },
    "tenant_id": {
      "type": "string",
      "pattern": "^tenant_[A-Za-z0-9_-]+$"
    },
    "repository_id": {
      "type": "string",
      "pattern": "^repo_[A-Za-z0-9_-]+$"
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "kind": {
      "enum": [
        "sprint_plan",
        "context_pack",
        "patch",
        "test_report",
        "validation_report",
        "evidence_bundle",
        "decision",
        "conversation",
        "memory",
        "index_snapshot",
        "runtime_receipt"
      ]
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "validated",
        "rejected",
        "superseded",
        "archived",
        "quarantined"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "media_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "storage_uri": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2048
    },
    "size_bytes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "validated_by": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^artifact_[A-Za-z0-9_-]+$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_refs"
      ],
      "properties": {
        "source_type": {
          "enum": [
            "human",
            "agent",
            "compiler",
            "test",
            "runtime",
            "generated"
          ]
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "uniqueItems": true
        },
        "source_commit": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{7,64}$"
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}

