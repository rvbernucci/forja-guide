{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/artifact-bundle-manifest.schema.json",
  "title": "Forja Artifact Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "schema_version",
    "tenant_id",
    "repository_id",
    "family",
    "entries",
    "total_size_bytes",
    "source_refs",
    "created_by",
    "created_at"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "pattern": "^manifest_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "schema_version": {"const": "1.0"},
    "tenant_id": {
      "type": "string",
      "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "repository_id": {
      "type": "string",
      "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "family": {
      "enum": ["evidence", "conversation_transcript", "dataset", "report", "snapshot"]
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["logical_path", "artifact_id", "content_hash", "size_bytes", "media_type"],
        "properties": {
          "logical_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"
          },
          "artifact_id": {
            "type": "string",
            "pattern": "^artifact_[A-Za-z0-9_-]+$"
          },
          "content_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4294967296
          },
          "media_type": {"type": "string", "minLength": 3, "maxLength": 120}
        }
      }
    },
    "total_size_bytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 17179869184
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "created_by": {"type": "string", "minLength": 1, "maxLength": 160},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
