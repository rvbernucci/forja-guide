{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/retrieval-preflight-receipt.schema.json",
  "title": "Forja Retrieval Preflight Receipt",
  "description": "Redacted proof that the governed retrieval runtime dependencies passed their bounded preflight.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generation", "postgres_ready", "qdrant_verified", "bedrock_dimensions"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "generation": {"type": "string", "pattern": "^retrieval_generation_[a-f0-9]{64}$"},
    "postgres_ready": {"const": true},
    "qdrant_verified": {"const": true},
    "bedrock_dimensions": {"const": 1024}
  }
}
