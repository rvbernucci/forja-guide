{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/evidence-manifest.schema.json",
  "title": "Forja Delivery Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["delivery_id", "schema_version", "entries"],
  "properties": {
    "delivery_id": {"type": "string", "pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "schema_version": {"const": "1.0"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes", "media_type"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 4096},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0, "maximum": 1073741824},
          "media_type": {"type": "string", "minLength": 1, "maxLength": 255}
        }
      }
    }
  }
}
