{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/validation-report.schema.json",
  "title": "Forja Independent Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_id", "delivery_id", "tenant_id", "repository_id", "schema_version", "status",
    "base_commit", "result_commit", "patch_sha256", "author_id",
    "validator_id", "clean_checkout", "checks", "created_at"
  ],
  "properties": {
    "validation_id": {"type": "string", "pattern": "^validation_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "delivery_id": {"type": "string", "pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "tenant_id": {"type": "string", "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "schema_version": {"const": "1.1"},
    "status": {"enum": ["passed", "failed"]},
    "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "result_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "patch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "author_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "validator_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "clean_checkout": {"type": "boolean"},
    "checks": {
      "type": "array", "minItems": 1, "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id", "kind", "status", "started_at", "finished_at",
          "duration_ms", "stdout_sha256", "stderr_sha256"
        ],
        "properties": {
          "check_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,119}$"},
          "kind": {"enum": ["built_in", "configured", "independent"]},
          "status": {"enum": ["passed", "failed"]},
          "started_at": {"type": "string", "format": "date-time"},
          "finished_at": {"type": "string", "format": "date-time"},
          "duration_ms": {"type": "integer", "minimum": 0},
          "exit_code": {"type": ["integer", "null"]},
          "command_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "detail": {"type": ["string", "null"], "maxLength": 4000}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "passed"}},
        "required": ["status"]
      },
      "then": {"properties": {"clean_checkout": {"const": true}}}
    }
  ]
}
