{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.dev/schemas/delivery-request.schema.json",
  "title": "Forja Delivery Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "delivery_id", "tenant_id", "repository_id", "task_id", "attempt_id", "run_id", "schema_version",
    "repository_path", "worktree_root", "base_commit", "publication_ref", "publication_previous_commit",
    "author_id", "validator_id", "role", "objective", "read_scopes",
    "write_scopes", "artifact_scopes", "evidence_scope", "attempt_ordinal",
    "worker_budgets", "mechanical_validator_ids", "lease_ttl_ms"
  ],
  "properties": {
    "delivery_id": {"type": "string", "pattern": "^delivery_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "tenant_id": {"type": "string", "pattern": "^tenant_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "repository_id": {"type": "string", "pattern": "^repo_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "run_id": {"type": "string", "pattern": "^run_[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "schema_version": {"const": "1.1"},
    "repository_path": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "worktree_root": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "publication_ref": {"type": "string", "pattern": "^refs/forja/deliveries/[A-Za-z0-9][A-Za-z0-9._/-]{0,255}$"},
    "publication_previous_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "author_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "validator_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "role": {"enum": ["implementer", "tester"]},
    "objective": {"type": "string", "minLength": 3, "maxLength": 8000},
    "read_scopes": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "write_scopes": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "artifact_scopes": {
      "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "evidence_scope": {"type": "string", "minLength": 1, "maxLength": 1024},
    "context_pack_ref": {"type": ["string", "null"], "pattern": "^(artifact|context)_[A-Za-z0-9_-]+$"},
    "attempt_ordinal": {"type": "integer", "minimum": 1},
    "model": {"type": ["string", "null"], "minLength": 1, "maxLength": 200},
    "worker_budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_clock_ms", "inactivity_ms", "max_output_bytes", "cancellation_grace_ms", "max_retries"],
      "properties": {
        "wall_clock_ms": {"type": "integer", "minimum": 100, "maximum": 86400000},
        "inactivity_ms": {"type": "integer", "minimum": 100, "maximum": 3600000},
        "max_output_bytes": {"type": "integer", "minimum": 1024, "maximum": 16777216},
        "cancellation_grace_ms": {"type": "integer", "minimum": 10, "maximum": 30000},
        "max_retries": {"type": "integer", "minimum": 0, "maximum": 10},
        "max_tokens": {"type": ["integer", "null"], "minimum": 1},
        "max_commands": {"type": ["integer", "null"], "minimum": 1, "maximum": 10000}
      }
    },
    "mechanical_validator_ids": {
      "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,119}$"}
    },
    "lease_ttl_ms": {"type": "integer", "minimum": 1000, "maximum": 86400000}
  }
}
