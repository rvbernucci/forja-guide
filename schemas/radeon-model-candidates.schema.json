{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forja.guide/schemas/radeon-model-candidates.schema.json",
  "title": "Radeon Local Model Candidates",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidates"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "candidate_set_id": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "base_url", "model"],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "base_url": {
            "type": "string",
            "pattern": "^https?://(localhost|127(?:\\.[0-9]{1,3}){3}|\\[::1\\])(:[0-9]{1,5})?(/.*)?$"
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "server": {
            "type": "string",
            "enum": ["vllm", "sglang", "llama.cpp", "litert", "other"]
          },
          "quantization": {
            "type": "string",
            "minLength": 1
          },
          "expected_context_tokens": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
